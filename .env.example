# Resend API key — scoped to "Sending access" only.
# Generate in Resend dashboard at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. Must be on a Resend-verified domain.
FROM_EMAIL=Booker AI <austin@getbookerai.com>

# Comma-separated list of recipient email addresses for office notifications.
# PROD example: office@allpointshvac.com,austin@getbookerai.com
# TEST example: austin@getbookerai.com
OFFICE_EMAIL_RECIPIENTS=

# Client business name — appears in the email footer.
CLIENT_BUSINESS_NAME=AllPoints HVAC

# Manny's Oil Company business name — appears in the footer for the
# 2 Manny's Oil endpoints. Two businesses share this backend.
MANNY_BUSINESS_NAME=Manny's Oil Company

# Set to "true" to bypass real Resend sends for /vendor_message and
# write to data/messages.jsonl instead. Local-dev convenience.
# Default: false (real Resend sends).
USE_STUB_VENDOR_MESSAGE=false

# --- ElevenLabs post-call webhook → Booker dashboard ---

# Lovable edge function that ingests post-call webhook events.
# Same URL on PROD and TEST.
BOOKER_WEBHOOK_URL=

# Shared secret sent as the x-webhook-secret header. Same value across
# PROD and TEST; matches what the Lovable edge function validates.
BOOKER_WEBHOOK_SECRET=

# Whether /elevenlabs_post_call forwards events to the Booker dashboard.
# PROD: true. TEST: false (accepts and logs without forwarding, so test
# calls do not pollute the production dashboard). Default: true.
POST_CALL_WEBHOOK_FORWARDING_ENABLED=true

# --- Urgent call orchestration ---

# Twilio account credentials. Same Twilio account on PROD and TEST.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15084655351

# Supabase (shared database between PROD and TEST). Service-role key
# bypasses RLS so the backend can read/write urgent_call_attempts.
SUPABASE_URL=https://snmzbjmddgukamuknbxr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Phone number to call for urgent dispatches.
# PROD example: +15087699785   (Manny's cell)
# TEST example: +12065364398   (Austin's cell)
URGENT_CALL_RECIPIENT_PHONE=

# Compress the 90s/30s retry timings to 10s/3s for manual
# integration testing. PROD: unset (defaults to false).
# TEST: set to true if you want a fast loop.
URGENT_CALL_FAST_MODE=false

# Public custom domain the FastAPI app serves on. Twilio fetches
# TwiML and POSTs Gather/status callbacks at this base URL.
# PROD example: https://allpoints-api.getbookerai.com
# TEST example: https://allpoints-api-test.getbookerai.com
PUBLIC_BASE_URL=
